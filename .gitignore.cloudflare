# Cloudflare deployment specific .gitignore

# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Cloudflare
.wrangler/
wrangler.toml.backup

# Environment files
.env
.env.local
.env.production
.env.test

# Logs
*.log
logs/

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# Dependency directories
.pnp
.pnp.js

# Build outputs
dist/
build/client/
build/

# MacOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Temporary files
*.tmp
*.temp
temp/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# Trajectory files (from agent execution)
trajectory_*.json